    "app.tagline" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حوّل راتبك إلى شيء يمكنك أن تشعر به فعلاً."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Proměňte plat v něco, co opravdu pocítíte."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gør din løn til noget, du faktisk kan mærke."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mach dein Gehalt zu etwas, das du wirklich spüren kannst."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Κάνε τον μισθό σου κάτι που μπορείς πραγματικά να νιώσεις."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Turn salary into something you can actually feel."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Convierte tu sueldo en algo que de verdad puedas sentir."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Muuta palkka joksikin, jonka voi oikeasti tuntea."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gawing isang bagay na talagang mararamdaman ang suweldo mo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transformez votre salaire en quelque chose de concret."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "הפכו את המשכורת למשהו שאפשר ממש להרגיש."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपनी सैलरी को ऐसी चीज़ में बदलें जिसे आप सच में महसूस कर सकें।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tedd a fizetésedet valami olyanná, amit tényleg érezni lehet."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ubah gaji Anda menjadi sesuatu yang benar-benar terasa nyata."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trasforma il tuo stipendio in qualcosa di davvero concreto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "給料を本当に実感できるものに変えよう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "급여를 실제로 체감되는 것으로 바꾸세요."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jadikan gaji anda sesuatu yang benar-benar boleh dirasai."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gjør lønnen til noe du faktisk kan kjenne på."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maak van je salaris iets wat je echt kunt voelen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zamień pensję w coś, co naprawdę da się odczuć."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
